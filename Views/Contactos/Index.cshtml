@* ============================================================
   INDEX - Lista principal de contactos
   Muestra todos los contactos en una tabla con:
   - Buscador en tiempo real
   - Botones de editar y eliminar por fila
   - Modal de confirmación antes de eliminar
   - Botón para exportar todos los contactos a CSV
   ============================================================ *@

@model IEnumerable<ManoloCRM.Models.Contacto>
@{
    ViewData["Title"] = "Contactos";
}

@* ── ENCABEZADO DE LA PÁGINA ──────────────────────────────────
   Título a la izquierda, botones de acción a la derecha *@
<div class="d-flex justify-content-between align-items-start mb-1">
    <div>
        <div class="page-title">
            <i class="bi bi-person-lines-fill me-2"></i>Directorio de Contactos
        </div>
        <p class="page-subtitle">Gestión completa de contactos de Manolo Limitada</p>
    </div>
    <div class="d-flex gap-2">
        @* Exportar CSV: llama al método ExportarCsv() del controlador
           Descarga un archivo .csv compatible con Excel en español *@
        <a asp-action="ExportarCsv" class="btn btn-success btn-sm">
            <i class="bi bi-file-earmark-spreadsheet me-1"></i>Exportar CSV
        </a>
        <a asp-action="Crear" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Nuevo Contacto
        </a>
    </div>
</div>

@* ── TABLA DE CONTACTOS ───────────────────────────────────────*@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">

        @* Contador que se actualiza en tiempo real con JavaScript *@
        <span>
            <i class="bi bi-table me-2"></i>
            Contactos registrados (<span id="contadorVisible">@Model.Count()</span>)
        </span>

        @* ── BUSCADOR EN TIEMPO REAL ──────────────────────────
           El evento "oninput" llama a filtrarTabla() con cada tecla
           No recarga la página - filtra las filas con JavaScript *@
        <div class="input-group" style="max-width:280px;">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input type="text" id="buscador"
                   class="form-control border-start-0 ps-0"
                   placeholder="Buscar contacto..."
                   oninput="filtrarTabla()" />
        </div>
    </div>

    <div class="card-body p-0">

        @* Si no hay contactos mostrar mensaje y botón para crear *@
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <p class="mt-3 text-muted">No hay contactos registrados aún.</p>
                <a asp-action="Crear" class="btn btn-primary">
                    <i class="bi bi-plus me-1"></i>Registrar primer contacto
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Cédula</th>
                            <th>Nombre completo</th>
                            <th>Fecha Nac.</th>
                            <th>Edad</th>
                            <th>Teléfono</th>
                            <th>Dirección</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    @* id="tbody" es necesario para que JavaScript
                       pueda encontrar las filas al filtrar *@
                    <tbody id="tbody">
                        @foreach (var c in Model)
                        {
                            <tr>
                                <td><code>@c.Cedula</code></td>

                                @* Avatar con iniciales + nombre completo *@
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar-mini">
                                            @c.Nombre[0]@c.Apellidos[0]
                                        </div>
                                        <span class="fw-semibold">@c.NombreCompleto</span>
                                    </div>
                                </td>

                                <td>@c.FechaNacimiento.ToString("dd/MM/yyyy")</td>

                                @* La edad se muestra calculada - no viene de la BD *@
                                <td><span class="badge-edad">@c.Edad años</span></td>

                                <td>
                                    <i class="bi bi-telephone me-1 text-muted"></i>
                                    @c.Telefono
                                </td>
                                <td class="text-muted small">@c.Direccion</td>

                                <td class="text-center">
                                    @* Editar: va al formulario con los datos cargados *@
                                    <a asp-action="Editar" asp-route-id="@c.Id"
                                       class="btn btn-warning btn-sm me-1">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>

                                    @* Eliminar: NO elimina directo - abre el modal
                                       de confirmación pasando el ID y nombre *@
                                    <button type="button" class="btn btn-danger btn-sm"
                                            onclick="confirmarEliminar(@c.Id, '@c.NombreCompleto')">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Mensaje que aparece cuando el buscador no encuentra resultados
               Oculto por defecto (d-none), se muestra con JavaScript *@
            <div id="sinResultados" class="text-center py-4 d-none">
                <i class="bi bi-search fs-2 text-muted"></i>
                <p class="mt-2 text-muted">No se encontraron resultados.</p>
            </div>
        }
    </div>
</div>

@* ── MODAL DE CONFIRMACIÓN DE ELIMINACIÓN ────────────────────
   Se muestra al hacer clic en el botón eliminar de cualquier fila
   JavaScript llena el nombre y la URL del formulario dinámicamente
   Solo hay un modal para todos los contactos - se reutiliza *@
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <div class="text-danger fs-1">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
            </div>
            <div class="modal-body text-center px-4">
                <h5 class="fw-bold mt-1">Eliminar contacto</h5>
                <p class="text-muted">
                    ¿Estás seguro que deseas eliminar a<br>
                    @* JavaScript llena este span con el nombre del contacto *@
                    <strong id="nombreEliminar" class="text-dark"></strong>?
                </p>
                <p class="text-muted small">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2 pt-0">
                <button type="button" class="btn btn-secondary px-4"
                        data-bs-dismiss="modal">Cancelar</button>

                @* JavaScript actualiza el action de este form con el ID correcto *@
                <form id="formEliminar" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i>Sí, eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@* Estilos del avatar mini en la tabla *@
<style>
    .avatar-mini {
        width: 34px; height: 34px; border-radius: 50%;
        background: linear-gradient(135deg, #1967d2, #4285f4);
        color: #fff; display: flex; align-items: center;
        justify-content: center; font-weight: 700;
        font-size: .78rem; flex-shrink: 0; text-transform: uppercase;
    }
</style>

@* ── SCRIPTS ──────────────────────────────────────────────────
   Se renderizan al final del _Layout gracias a @section Scripts
   Así no bloquean la carga del HTML *@
@section Scripts {
<script>
    // ── BUSCADOR EN TIEMPO REAL ───────────────────────────────
    // Se ejecuta con cada tecla que el usuario presiona
    // Busca el texto en TODO el contenido de cada fila (todas las columnas)
    function filtrarTabla() {
        const texto = document.getElementById("buscador").value.toLowerCase();
        const filas = document.querySelectorAll("#tbody tr");
        let visibles = 0;

        filas.forEach(fila => {
            // Verificar si el texto buscado está en alguna celda de la fila
            const coincide = fila.textContent.toLowerCase().includes(texto);
            fila.style.display = coincide ? "" : "none";
            if (coincide) visibles++;
        });

        // Actualizar el contador con la cantidad de filas visibles
        document.getElementById("contadorVisible").textContent = visibles;

        // Mostrar u ocultar el mensaje "sin resultados"
        const sinResultados = document.getElementById("sinResultados");
        if (sinResultados)
            sinResultados.classList.toggle("d-none", visibles > 0);
    }

    // ── MODAL DE ELIMINACIÓN ──────────────────────────────────
    // Recibe el ID y nombre del contacto desde el botón de la fila
    // Llena el modal con el nombre y apunta el form al endpoint correcto
    function confirmarEliminar(id, nombre) {
        // Mostrar el nombre del contacto en el modal
        document.getElementById("nombreEliminar").textContent = nombre;

        // Apuntar el formulario al endpoint con el ID correcto
        // POST /Contactos/EliminarConfirmado/{id}
        document.getElementById("formEliminar").action =
            "/Contactos/EliminarConfirmado/" + id;

        // Mostrar el modal usando la API de Bootstrap 5
        new bootstrap.Modal(document.getElementById("modalEliminar")).show();
    }
</script>
}