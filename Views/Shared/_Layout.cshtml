<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Manolo Limitada</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background-color: #f0f2f5; margin: 0; }

        /* ── NAVBAR ── */
        .navbar {
            background: linear-gradient(90deg, #1a1a2e, #16213e) !important;
            box-shadow: 0 2px 10px rgba(0,0,0,.3);
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            height: 60px;
        }
        .navbar-brand { font-weight: 700; font-size: 1.3rem; letter-spacing: 1px; }

        /* ── SIDEBAR ── */
        #sidebar {
            position: fixed; top: 60px; left: 0; bottom: 0;
            width: 230px;
            background: #ffffff;
            box-shadow: 2px 0 10px rgba(0,0,0,.08);
            transition: width 0.25s ease, opacity 0.25s ease;
            overflow: hidden;
            z-index: 999;
        }
        #sidebar.collapsed { width: 0; opacity: 0; }

        .sidebar-inner { width: 230px; padding-top: 16px; }

        .sidebar-inner .nav-link {
            color: #444; padding: 10px 20px;
            border-radius: 8px; margin: 3px 10px;
            font-size: .93rem; white-space: nowrap;
            display: flex; align-items: center; gap: 10px;
        }
        .sidebar-inner .nav-link:hover,
        .sidebar-inner .nav-link.active {
            background: #e8f0fe; color: #1967d2;
        }
        .sidebar-inner .nav-link i { font-size: 1.05rem; width: 20px; text-align: center; }
        .sidebar-inner hr { margin: 8px 16px; border-color: #eee; }

        /* ── CONTENIDO PRINCIPAL ── */
        #main-content {
            margin-left: 230px;
            margin-top: 60px;
            padding: 30px;
            transition: margin-left 0.25s ease;
            min-height: calc(100vh - 60px);
        }
        #main-content.expanded { margin-left: 0; }

        /* ── BOTÓN TOGGLE ── */
        .btn-toggle {
            background: none; border: none; color: white;
            font-size: 1.3rem; padding: 4px 10px;
            cursor: pointer; border-radius: 6px;
            transition: background 0.2s;
        }
        .btn-toggle:hover { background: rgba(255,255,255,0.15); }

        /* ── CARDS Y TABLA ── */
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,.08); }
        .card-header {
            background: linear-gradient(90deg, #1967d2, #1a73e8);
            color: #fff; border-radius: 12px 12px 0 0 !important;
            padding: 15px 20px; font-weight: 600;
        }
        .btn-primary { background: #1967d2; border-color: #1967d2; }
        .btn-primary:hover { background: #1557b0; }
        .table thead th {
            background: #f8f9ff; color: #555; font-weight: 600;
            border-bottom: 2px solid #dee2e6;
            text-transform: uppercase; font-size: .78rem; letter-spacing: .5px;
        }
        .badge-edad {
            background: #e8f0fe; color: #1967d2;
            font-weight: 600; padding: 5px 10px;
            border-radius: 20px; font-size: .85rem;
        }
        .page-title { font-size: 1.6rem; font-weight: 700; color: #1a1a2e; margin-bottom: 5px; }
        .page-subtitle { color: #888; font-size: .9rem; margin-bottom: 25px; }

        footer {
            text-align: center; padding: 15px;
            color: #999; font-size: .82rem;
            border-top: 1px solid #e9ecef; margin-top: 40px;
        }
    </style>
</head>
<body>

<!-- ── NAVBAR ── -->
<nav class="navbar navbar-expand-lg navbar-dark px-3">
    <div class="d-flex align-items-center gap-2">
        <!-- Botón para plegar/desplegar el sidebar -->
        @if (Context.Session.GetString("UsuarioLogueado") != null)
        {
            <button class="btn-toggle" id="toggleSidebar" title="Menú">
                <i class="bi bi-list"></i>
            </button>
        }
        <a class="navbar-brand text-white mb-0" href="/Contactos/Dashboard">
            <i class="bi bi-people-fill me-2"></i>Manolo Limitada
        </a>
    </div>

    @if (Context.Session.GetString("UsuarioLogueado") != null)
    {
        <div class="ms-auto d-flex align-items-center gap-2">
            <span class="text-white small">
                <i class="bi bi-person-circle me-1"></i>
                @Context.Session.GetString("UsuarioLogueado")
            </span>
            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
            </a>
        </div>
    }
</nav>

@if (Context.Session.GetString("UsuarioLogueado") != null)
{
    <!-- ── SIDEBAR ── -->
    <div id="sidebar">
        <div class="sidebar-inner">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(Context.Request.Path.Value == "/Contactos/Dashboard" ? "active" : "")"
                       href="/Contactos/Dashboard">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Context.Request.Path.Value != null && Context.Request.Path.Value.StartsWith("/Contactos/Index") ? "active" : "")"
                       href="/Contactos/Index">
                        <i class="bi bi-person-lines-fill"></i> Contactos
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Context.Request.Path.Value == "/Contactos/Crear" ? "active" : "")"
                       href="/Contactos/Crear">
                        <i class="bi bi-person-plus-fill"></i> Nuevo Contacto
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- ── CONTENIDO PRINCIPAL ── -->
    <div id="main-content">
        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Exito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
        <footer>&copy; 2024 Manolo Limitada &mdash; Sistema de Gestión de Contactos</footer>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Sidebar toggle
    const toggle = document.getElementById("toggleSidebar");
    const sidebar = document.getElementById("sidebar");
    const main = document.getElementById("main-content");

    // Recordar estado entre páginas
    if (localStorage.getItem("sidebarCollapsed") === "true") {
        sidebar.classList.add("collapsed");
        main.classList.add("expanded");
    }

    toggle?.addEventListener("click", () => {
        const isCollapsed = sidebar.classList.toggle("collapsed");
        main.classList.toggle("expanded");
        localStorage.setItem("sidebarCollapsed", isCollapsed);
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>