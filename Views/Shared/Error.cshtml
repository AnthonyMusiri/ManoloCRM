@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="page-title text-danger">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>Ocurrió un error
</div>
<p class="page-subtitle">Algo salió mal. Por favor intenta de nuevo.</p>

<div class="card">
    <div class="card-body text-center py-5">
        <i class="bi bi-bug fs-1 text-muted"></i>
        <p class="mt-3 text-muted">Si el problema persiste, contacta al administrador.</p>
        <a href="/Contactos/Dashboard" class="btn btn-primary">
            <i class="bi bi-house me-1"></i>Volver al inicio
        </a>
    </div>
</div>