@model ManoloCRM.Models.LoginViewModel
@{
ViewData["Title"] = "Iniciar Sesión";
Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Manolo Limitada</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460); min-height:100vh; display:flex; align-items:center; justify-content:center; }
        .login-card { background:#fff; border-radius:20px; padding:45px; width:420px; box-shadow:0 20px 60px rgba(0,0,0,.4); }
        .login-logo { width:70px; height:70px; background:linear-gradient(135deg,#1967d2,#1a73e8); border-radius:18px; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; font-size:2rem; color:#fff; }
        .login-title { text-align:center; font-weight:800; font-size:1.5rem; color:#1a1a2e; margin-bottom:5px; }
        .login-subtitle { text-align:center; color:#aaa; font-size:.88rem; margin-bottom:30px; }
        .form-label { font-weight:600; color:#444; font-size:.9rem; }
        .form-control { border-radius:10px; padding:12px 15px; border:2px solid #e9ecef; }
        .form-control:focus { border-color:#1967d2; box-shadow:0 0 0 3px rgba(25,103,210,.1); }
        .btn-login { background:linear-gradient(90deg,#1967d2,#1a73e8); border:none; border-radius:10px; padding:13px; font-size:1rem; font-weight:600; width:100%; color:#fff; margin-top:10px; }
        .btn-login:hover { transform:translateY(-1px); box-shadow:0 5px 15px rgba(25,103,210,.4); color:#fff; }
        .hint-box { background:#f0f7ff; border-left:4px solid #1967d2; border-radius:8px; padding:12px 15px; margin-top:20px; font-size:.82rem; color:#555; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo"><i class="bi bi-people-fill"></i></div>
        <h1 class="login-title">Manolo Limitada</h1>
        <p class="login-subtitle">Sistema de Gestión de Contactos</p>
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @Html.ValidationSummary(true)
        </div>
    }

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label asp-for="Usuario" class="form-label">
                <i class="bi bi-person me-1"></i>Usuario
            </label>
            <input asp-for="Usuario" class="form-control" placeholder="Ingresa tu usuario" />
            <span asp-validation-for="Usuario" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label">
                <i class="bi bi-lock me-1"></i>Contraseña
            </label>
            <input asp-for="Password" class="form-control" placeholder="Ingresa tu contraseña" />
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>
        <button type="submit" class="btn btn-login">
            <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar al sistema
        </button>
    </form>

    <div class="hint-box">
        <strong>Credenciales:</strong><br />
        Usuario: <code>admin</code> &nbsp;|&nbsp; Contraseña: <code>admin123</code>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>